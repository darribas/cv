{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://darribas.org/cv/cv.schema.json",
  "title": "CV",
  "description": "Structured source of truth for the CV body. Publications live separately as CSL-JSON (see publications.json). The renderer (cv.typ) reads only keys it knows, so any key beginning with '//' is treated as a comment and ignored.",
  "type": "object",
  "required": ["basics", "sections"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Path to this schema, enabling editor autocomplete/validation."
    },
    "basics": { "$ref": "#/$defs/basics" },
    "sections": {
      "type": "array",
      "description": "Ordered list of CV sections. Order here is render order.",
      "items": { "$ref": "#/$defs/section" }
    }
  },
  "patternProperties": { "^//": { "$ref": "#/$defs/comment" } },
  "additionalProperties": false,
  "$defs": {
    "comment": {
      "description": "Free-text annotation ignored by the renderer.",
      "type": ["string", "array", "object", "number", "boolean"]
    },
    "basics": {
      "type": "object",
      "description": "Top-of-page identity block.",
      "required": ["name", "affiliation", "email", "url"],
      "properties": {
        "name": { "type": "string", "description": "Full name, shown large and centred." },
        "title": { "type": "string", "description": "Document heading, e.g. 'Curriculum Vitae'." },
        "affiliation": {
          "type": "array",
          "description": "Postal address lines, rendered one per line under the name.",
          "items": { "type": "string" }
        },
        "email": { "type": "string", "format": "email" },
        "url": { "type": "string", "format": "uri" }
      },
      "patternProperties": { "^//": { "$ref": "#/$defs/comment" } },
      "additionalProperties": false
    },
    "section": {
      "type": "object",
      "required": ["title", "type"],
      "properties": {
        "title": { "type": "string", "description": "Heading text; becomes a PDF bookmark." },
        "type": {
          "description": "Discriminator selecting the entry shape and how the renderer formats it.",
          "enum": ["education", "appointments", "research-income", "publications"]
        },
        "note": { "$ref": "#/$defs/comment" },
        "entries": {
          "type": "array",
          "description": "The section's items. Shape depends on 'type'."
        },
        "source": {
          "type": "string",
          "description": "Path to a CSL-JSON file. Used only when type is 'publications'."
        }
      },
      "patternProperties": { "^//": { "$ref": "#/$defs/comment" } },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "required": ["type"], "properties": { "type": { "const": "education" } } },
          "then": { "properties": { "entries": { "items": { "$ref": "#/$defs/educationEntry" } } } }
        },
        {
          "if": { "required": ["type"], "properties": { "type": { "const": "appointments" } } },
          "then": { "properties": { "entries": { "items": { "$ref": "#/$defs/appointmentEntry" } } } }
        },
        {
          "if": { "required": ["type"], "properties": { "type": { "const": "research-income" } } },
          "then": { "properties": { "entries": { "items": { "$ref": "#/$defs/incomeEntry" } } } }
        },
        {
          "if": { "required": ["type"], "properties": { "type": { "const": "publications" } } },
          "then": { "required": ["source"] }
        }
      ]
    },
    "educationEntry": {
      "type": "object",
      "required": ["date", "degree", "institution"],
      "properties": {
        "date": { "type": "string", "description": "Year of award, e.g. '2010'." },
        "degree": { "type": "string", "description": "e.g. 'PhD Economics'." },
        "institution": { "type": "string" },
        "location": { "type": "string", "description": "Country/city, shown in parentheses." },
        "thesis": { "type": "string", "description": "Thesis/dissertation title, shown italic." },
        "supervisor": { "type": "string" },
        "committee": { "type": "string" },
        "note": { "$ref": "#/$defs/comment" }
      },
      "patternProperties": { "^//": { "$ref": "#/$defs/comment" } },
      "additionalProperties": false
    },
    "appointmentEntry": {
      "type": "object",
      "required": ["date", "role"],
      "properties": {
        "date": { "type": "string", "description": "Year or range; open ranges end with '-', e.g. '2022-'." },
        "role": { "type": "string" },
        "organisation": { "type": "string" },
        "note": { "$ref": "#/$defs/comment" }
      },
      "patternProperties": { "^//": { "$ref": "#/$defs/comment" } },
      "additionalProperties": false
    },
    "incomeEntry": {
      "type": "object",
      "required": ["funder", "title", "role"],
      "properties": {
        "date": {
          "type": "string",
          "description": "Award year. Always give the true year: the renderer prints it once per run of same-year entries and blanks the repeats, reproducing the CV's blank-label convention."
        },
        "funder": { "type": "string", "description": "Awarding body, shown italic." },
        "title": { "type": "string", "description": "Project/grant title." },
        "scheme": { "type": "string", "description": "Funding scheme or programme." },
        "role": { "type": "string", "description": "e.g. 'PI', 'CoI', 'Scholar'." },
        "period": { "type": "string", "description": "Award period, e.g. '2024/29'." },
        "amount": { "$ref": "#/$defs/amount" },
        "note": { "$ref": "#/$defs/comment" }
      },
      "patternProperties": { "^//": { "$ref": "#/$defs/comment" } },
      "additionalProperties": false
    },
    "amount": {
      "type": "object",
      "description": "A monetary figure. The renderer picks the symbol from 'currency', so the source never hard-codes £/€/$.",
      "required": ["value", "currency"],
      "properties": {
        "value": { "type": "number", "description": "Numeric amount, no separators, e.g. 6788641." },
        "currency": { "enum": ["GBP", "EUR", "USD"] }
      },
      "additionalProperties": false
    }
  }
}
